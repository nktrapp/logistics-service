{
  "branches": ["main"],
  "tagFormat": "v${version}",
  "plugins": [
    "@semantic-release/commit-analyzer",
    "@semantic-release/release-notes-generator",
    [
      "@semantic-release/changelog",
      { "changelogFile": "CHANGELOG.md" }
    ],
    [
      "@semantic-release/exec",
      {
        "prepareCmd": "sed -i 's/^version=.*/version=${nextRelease.version}/' gradle.properties",
        "publishCmd": "docker buildx build -f application/Dockerfile --platform linux/amd64,linux/arm64 -t ${process.env.IMAGE}:${nextRelease.version} -t ${process.env.IMAGE}:latest --push ."
      }
    ],
    [
      "@semantic-release/git",
      {
        "assets": ["gradle.properties", "CHANGELOG.md"],
        "message": "chore(release): ${nextRelease.version} [skip ci]\n\n${nextRelease.notes}"
      }
    ],
    "@semantic-release/github"
  ]
}
